# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/orbit_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Environment
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3001
# Comma-separated list for additional production/staging frontends
CLIENT_ORIGINS=https://orbit.torusdxn.in,https://your-app.vercel.app

# React App (for client .env.local)
REACT_APP_API_URL=http://localhost:4000/api
